# =========================
# ENV / SECRETS
# =========================
.env
.env.local
.env.production
.env.development

backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production
render-worker/.env

# Nunca subir chaves reais
*.key
*.pem
*.crt
*.p12

# =========================
# PYTHON
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
.python-version
.venv/
venv/
env/

backend/__pycache__/
backend/temp/
backend/input/*
!backend/input/.gitkeep
backend/output/*
!backend/output/.gitkeep

# Arquivos gerados/local
backend/assets/logo.png
backend/assets/background_music.mp3
backend/assets/cta_audio.mp3

# Pasta de assets raiz (logos e mídias de usuário)
assets/

# Pasta de input raiz (vídeos brutos)
input/*
!input/.gitkeep

# Pasta de output raiz (vídeos renderizados)
output/*
!output/.gitkeep

# Arquivos de mídia grandes
*.MP4
*.mp4
*.MOV
*.mov
*.avi
*.mkv
*.mp3
*.wav
*.aac

# =========================
# RENDER WORKER
# =========================
render-worker/temp/
render-worker/logs/
render-worker/__pycache__/
render-worker/*.pyc

# =========================
# NODE / FRONTEND
# =========================
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
dist/
build/

# =========================
# OS / EDITOR
# =========================
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# =========================
# LOGS
# =========================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*